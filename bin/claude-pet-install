#!/usr/bin/env python3
"""claude-pet one-stop installer (cross-platform).

Checks PyQt6, registers the Claude Code hooks, and links the /claude-pet skill
into ~/.claude/skills/. Idempotent.

    claude-pet-install            install (hooks + skill)
    claude-pet-install --remove   uninstall (hooks + skill link; source stays)
"""
import os
import subprocess
import sys

HERE = os.path.dirname(os.path.abspath(__file__))
ROOT = os.path.dirname(HERE)
HOOKS = os.path.join(HERE, "claude-pet-install-hooks")
SKILLS_DIR = os.path.expanduser(os.path.join("~", ".claude", "skills"))
SKILL_LINK = os.path.join(SKILLS_DIR, "claude-pet")
SKILL_SRC = os.path.join(ROOT, "skills", "claude-pet")


def _link_skill():
    os.makedirs(SKILLS_DIR, exist_ok=True)
    if os.path.exists(SKILL_LINK) and not os.path.islink(SKILL_LINK):
        print("note:", SKILL_LINK, "exists and isn't a symlink — leaving it.",
              file=sys.stderr)
        return
    try:
        if os.path.islink(SKILL_LINK):
            os.unlink(SKILL_LINK)
        os.symlink(SKILL_SRC, SKILL_LINK, target_is_directory=True)
        print("linked /claude-pet skill ->", SKILL_LINK)
        return
    except OSError as e:                      # e.g. Windows without symlink priv
        if os.name == "nt" and _link_skill_junction():
            return
        print("could not link skill (%s). Link it manually:\n  %s -> %s"
              % (e, SKILL_LINK, SKILL_SRC), file=sys.stderr)


def _link_skill_junction():
    """Windows fallback: directory junctions don't need elevated privilege."""
    try:
        subprocess.check_call(
            ["cmd", "/c", "mklink", "/J", SKILL_LINK, SKILL_SRC],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        print("linked /claude-pet skill (junction) ->", SKILL_LINK)
        return True
    except (OSError, subprocess.CalledProcessError):
        return False


def _unlink_skill():
    if os.path.islink(SKILL_LINK):
        os.unlink(SKILL_LINK)
        print("unlinked /claude-pet skill")
    elif os.name == "nt" and os.path.isdir(SKILL_LINK):
        # os.path.islink() doesn't recognize Windows junctions; rmdir on a
        # junction removes just the link (leaves SKILL_SRC's contents intact),
        # but raises if this is actually a real, non-empty directory.
        try:
            os.rmdir(SKILL_LINK)
            print("unlinked /claude-pet skill")
        except OSError:
            pass


def main():
    remove = "--remove" in sys.argv[1:]
    if remove:
        subprocess.call([sys.executable, HOOKS, "--remove"])
        _unlink_skill()
        print("claude-pet uninstalled. (source stays at %s)" % ROOT)
        return
    try:
        __import__("PyQt6")
    except ImportError:
        print("warning: PyQt6 not found. Install it with:  pip install PyQt6",
              file=sys.stderr)
    subprocess.call([sys.executable, HOOKS])
    _link_skill()
    print("\nDone. Restart Claude Code sessions to pick up the hooks.")
    print("New sessions auto-spawn a pet; or run it now:")
    print("  %s %s" % (sys.executable, os.path.join(ROOT, "src", "pet.py")))


if __name__ == "__main__":
    main()
