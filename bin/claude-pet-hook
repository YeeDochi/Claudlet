#!/usr/bin/env python3
"""claude-pet-hook — per-session bridge between Claude Code and its pet.

Claude Code invokes this for each hook event (event name in argv[1], JSON
payload on stdin). It:
  * on SessionStart, launches a pet for this session if one isn't already
    running (launched from inside the session, so it inherits host app + env);
  * forwards every event to that session's unix socket
    ($XDG_RUNTIME_DIR/claude-pet-<session_id>.sock).

Must never block or fail Claude: every error is swallowed and exit is always 0.
"""
import sys
import os
import json
import socket
import subprocess

try:
    _HERE = os.path.dirname(os.path.abspath(__file__))
except NameError:
    _HERE = os.getcwd()
try:
    sys.path.insert(0, os.path.join(_HERE, "..", "src"))
    import hostinfo
except Exception:
    hostinfo = None


def build_message(argv, data):
    """Build the JSON line to send to the pet. Pure; unit-tested."""
    event = (argv[1] if len(argv) > 1 else "") or data.get("hook_event_name", "")
    msg = {"event": event, "session": data.get("session_id") or "default"}
    for key in ("tool_name", "notification_type", "error_type"):
        val = data.get(key)
        if val:
            msg[key] = val
    return json.dumps(msg) + "\n"


def sock_for(data):
    return hostinfo.session_sock(data.get("session_id") or "default")


def _pet_running(sock_path):
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(0.2)
    try:
        s.connect(sock_path)
        s.close()
        return True
    except OSError:
        return False


def _launch_pet(session_id, host):
    launcher = os.path.join(_HERE, "claude-pet")
    subprocess.Popen(
        [launcher, "--session", session_id, "--host", host],
        stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL, start_new_session=True)


def _send(sock_path, payload):
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(0.3)
    s.connect(sock_path)
    s.sendall(payload)
    s.close()


def main():
    if hostinfo is None:
        return
    raw = ""
    try:
        if not sys.stdin.isatty():
            raw = sys.stdin.read()
    except Exception:
        pass
    try:
        data = json.loads(raw) if raw.strip() else {}
    except Exception:
        data = {}

    event = (sys.argv[1] if len(sys.argv) > 1 else "") or data.get("hook_event_name", "")
    session_id = data.get("session_id") or "default"
    sock_path = hostinfo.session_sock(session_id)

    # on session start, bring up this session's pet if it isn't already there
    if event == "SessionStart":
        try:
            if not _pet_running(sock_path):
                _launch_pet(session_id, hostinfo.detect_host())
        except Exception:
            pass

    try:
        _send(sock_path, build_message(sys.argv, data).encode())
    except Exception:
        pass  # pet not running / not ready — ignore silently


if __name__ == "__main__":
    try:
        main()
    except Exception:
        pass
    sys.exit(0)   # hooks must always succeed
